# Database (Neon PostgreSQL — https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js v5
AUTH_SECRET=""                # openssl rand -base64 32
AUTH_GOOGLE_ID=""             # Google Cloud Console OAuth client ID
AUTH_GOOGLE_SECRET=""         # Google Cloud Console OAuth client secret
AUTH_RESEND_KEY=""            # Resend API key for magic-link emails

# Resend (transactional emails — https://resend.com)
RESEND_API_KEY=""

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Nimbus Platform (AWS cross-account trust)
NIMBUS_PLATFORM_AWS_ACCOUNT_ID="123456789012"

# Vercel deploy
VERCEL_TOKEN=""
