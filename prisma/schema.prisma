generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// Auth.js v5 models
// =====================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  memberships  TenantMember[]
  ownedTenants Tenant[]       @relation("TenantOwner")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =====================================================================
// Platform (global) entities
// =====================================================================

model PlatformSetupState {
  id                  String    @id @default(cuid())
  setupCompleted      Boolean   @default(false)
  setupPath           String?
  initialAdminUserId  String?
  completedAt         DateTime?

  @@map("platform_setup_state")
}

model PlatformConfiguration {
  id                    String   @id @default(cuid())
  platformAwsAccountId  String
  externalIdStrategy    String   @default("per-integration")
  defaultRegion         String   @default("us-east-1")
  onboardingMode        String   @default("self-service")
  batchIntervalHours    Int      @default(24)
  createdAt             DateTime @default(now())

  @@map("platform_configuration")
}

model AdminUser {
  id                      String    @id @default(cuid())
  email                   String    @unique
  name                    String?
  role                    String    @default("admin")
  status                  String    @default("active")
  invitedByAdminUserId    String?
  createdAt               DateTime  @default(now())

  invitationsSent AdminInvitation[]        @relation("InvitedByAdmin")
  impersonations  AdminImpersonationSession[]

  @@map("admin_users")
}

model AdminInvitation {
  id                    String    @id @default(cuid())
  email                 String
  invitedByAdminUserId  String
  status                String    @default("pending")
  expiresAt             DateTime
  createdAt             DateTime  @default(now())
  acceptedAt            DateTime?

  invitedBy AdminUser @relation("InvitedByAdmin", fields: [invitedByAdminUserId], references: [id])

  @@map("admin_invitations")
}

model AdminImpersonationSession {
  id              String    @id @default(cuid())
  adminUserId     String
  tenantId        String
  reason          String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  status          String    @default("active")
  permissionsScope String?

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@map("admin_impersonation_sessions")
}

// =====================================================================
// Tenant core
// =====================================================================

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  plan         String   @default("TRIAL")
  status       String   @default("active")
  ownerUserId  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner          User                        @relation("TenantOwner", fields: [ownerUserId], references: [id])
  members        TenantMember[]
  invitations    TenantInvitation[]
  organizations  AwsOrganization[]
  accounts       AwsAccount[]
  ous            OrganizationalUnit[]
  integrations   Integration[]
  batches        CollectionBatch[]
  recommendations Recommendation[]
  freshness      DataFreshnessStatus[]
  billing        BillingSubscription?
  impersonations AdminImpersonationSession[]
  auditLogs      AuditLog[]

  @@map("tenants")
}

model TenantMember {
  id                String   @id @default(cuid())
  tenantId          String
  userId            String
  membershipStatus  String   @default("active")
  targetGroup       String   @default("owner") // owner | read
  joinedAt          DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_members")
}

model TenantInvitation {
  id                 String    @id @default(cuid())
  tenantId           String
  email              String
  invitedByUserId    String
  targetGroup        String    @default("read")
  status             String    @default("pending")
  expiresAt          DateTime
  createdAt          DateTime  @default(now())
  acceptedAt         DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_invitations")
}

// =====================================================================
// AWS Organization domain
// =====================================================================

model AwsOrganization {
  id                        String    @id @default(cuid())
  tenantId                  String
  organizationName          String
  organizationId            String
  managementAccountId       String
  delegatedAdminAccountId   String?
  organizationStatus        String    @default("pending")
  discoveredAt              DateTime?
  createdAt                 DateTime  @default(now())

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ous      OrganizationalUnit[]
  accounts AwsAccount[]

  @@map("aws_organizations")
}

model OrganizationalUnit {
  id              String  @id @default(cuid())
  tenantId        String
  organizationId  String
  ouId            String
  name            String
  parentOuId      String?

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization AwsOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organizational_units")
}

model AwsAccount {
  id             String  @id @default(cuid())
  tenantId       String
  organizationId String
  awsAccountId   String
  accountName    String
  ouId           String?
  accountType    String  @default("member")
  status         String  @default("active")

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization AwsOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integrations Integration[]

  @@map("aws_accounts")
}

// =====================================================================
// Integration
// =====================================================================

model Integration {
  id                         String    @id @default(cuid())
  tenantId                   String
  connectorType              String // aws_organizations, cur, cost_explorer, cost_optimization_hub, compute_optimizer, trusted_advisor, ssm_explorer
  integrationMode            String    @default("read") // read | tagging | action
  awsAccountRefId            String?
  roleArn                    String?
  externalId                 String
  trustPrincipalAccountId    String
  status                     String    @default("pending") // pending | active | error | partial
  healthStatus               String    @default("unknown")
  collectionFrequencyHours   Int       @default(24)
  lastSuccessfulCollection   DateTime?
  lastSuccessfulBatch        DateTime?
  lastError                  String?
  createdAt                  DateTime  @default(now())

  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  awsAccount AwsAccount?             @relation(fields: [awsAccountRefId], references: [id])
  testResults IntegrationTestResult[]

  @@map("integrations")
}

model IntegrationTestResult {
  id             String   @id @default(cuid())
  integrationId  String
  executedAt     DateTime @default(now())
  status         String   // ok | error
  serviceChecked String?
  errorDetails   String?

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@map("integration_test_results")
}

// =====================================================================
// Data plane
// =====================================================================

model CollectionBatch {
  id                String    @id @default(cuid())
  tenantId          String
  batchType         String    @default("daily")
  scheduledAt       DateTime
  startedAt         DateTime?
  finishedAt        DateTime?
  status            String    @default("scheduled") // scheduled | running | success | failed | partial
  recordsCollected  Int       @default(0)
  recordsFailed     Int       @default(0)
  errorDetails      String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("collection_batches")
}

model Recommendation {
  id                  String   @id @default(cuid())
  tenantId            String
  source              String // cost_optimization_hub | compute_optimizer | trusted_advisor
  awsAccountId        String?
  region              String?
  resourceId          String?
  recommendationType  String
  priority            String   @default("medium") // low | medium | high
  estimatedSavings    Decimal? @db.Decimal(12, 2)
  status              String   @default("open") // open | in_progress | dismissed | applied
  createdAt           DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("recommendations")
}

model DataFreshnessStatus {
  id                  String    @id @default(cuid())
  tenantId            String
  connectorType       String
  lastCollectedAt     DateTime?
  lastConsolidatedAt  DateTime?
  freshnessStatus     String    @default("unknown") // fresh | stale | delayed | unknown
  freshnessDelayHours Int       @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, connectorType])
  @@map("data_freshness_status")
}

// =====================================================================
// Billing & Audit
// =====================================================================

model BillingSubscription {
  id            String    @id @default(cuid())
  tenantId      String    @unique
  plan          String    @default("TRIAL") // TRIAL | PRO
  pricingModel  String    @default("usage_percent") // flat | usage_percent
  billingStatus String    @default("trial") // trial | active | past_due | canceled
  trialEndsAt   DateTime?
  createdAt     DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("billing_subscriptions")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  entityType  String
  entityId    String
  action      String
  actor       String
  actorType   String   @default("user") // user | admin | system
  timestamp   DateTime @default(now())
  metadataJson Json?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
